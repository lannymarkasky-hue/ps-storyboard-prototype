{
  "manifestVersion": 5,
  "id": "com.landon.storyboardprototype",
  "name": "Storyboard Prototype",
  "version": "0.0.1",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "storyboardPanel",
      "label": {
        "default": "Storyboard Prototype"
      },
      "minimumSize": {
        "width": 260,
        "height": 300
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 700
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  }
}
